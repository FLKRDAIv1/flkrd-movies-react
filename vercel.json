{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)\\.mobileconfig",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/x-apple-aspen-config"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/watch/:ticket_id",
      "destination": "/api/watch?ticket_id=:ticket_id"
    },
    {
      "source": "/details/movie/:id",
      "destination": "/api/seo?type=movie&id=:id"
    },
    {
      "source": "/details/tv/:id",
      "destination": "/api/seo?type=tv&id=:id"
    },
    {
      "source": "/dubbed-details/:id",
      "destination": "/api/seo?type=dubbed&id=:id"
    },
    {
      "source": "/((?!assets/|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
