{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "notification:allow-notify",
    "dialog:allow-all",
    "process:allow-restart",
    "os:allow-all",
    "shell:allow-all",
    "http:default"
  ]
}
