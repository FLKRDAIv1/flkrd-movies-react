# FLKRD Movies Environment Variable Template
# Copy this file to .env.local for local development

# TMDB (The Movie Database) API Keys
VITE_TMDB_API_KEY="your_tmdb_api_key_here"

# Subtitles APIs (OpenSubtitles keys can be comma-separated for rotation)
VITE_OPENSUBTITLES_API_KEY="key1,key2"
VITE_SUBDL_API_KEY="your_subdl_api_key_here"

# Supabase Configurations
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Novu Notifications (Optional)
REACT_APP_NOVU_APPLICATION_IDENTIFIER="your-novu-identifier"
NOVU_BACKEND_URL="https://api.novu.co"
NOVU_SOCKET_URL="https://ws.novu.co"
